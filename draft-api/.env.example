# Required for the Vector Database (Pinecone)
PINECONE_API_KEY="your-pinecone-api-key-here"

# Required for Cloud AI (Groq)
GROQ_API_KEY="your-groq-api-key-here"

# Set this to override the default local provider (ollama) if testing without Groq
# AI_PROVIDER="ollama"

# Required for persistent database storage (Neon PostgreSQL)
# Get your connection string from: https://console.neon.tech
# Format: postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="your-neon-connection-string-here"
